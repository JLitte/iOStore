# Variables de entorno requeridas para iOStore
# Copiá este archivo como .env y completá los valores reales (nunca subas .env al repo)

# Cadena de conexión a SQL Server
IOSTORE_DB_CONNECTION=

# SMTP — Gmail (usar App Password, no la contraseña personal)
IOSTORE_SMTP_HOST=smtp.gmail.com
IOSTORE_SMTP_PORT=587
IOSTORE_SMTP_USER=
IOSTORE_SMTP_PASSWORD=
