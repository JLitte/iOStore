@model iOStore.Models.TarifaEnvio
@{
    ViewData["Title"] = "Editar Tarifa";
    Layout = "/Views/Shared/_Layout.Admin.cshtml";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h3 class="fw-bold mb-0">
        <i class="bi bi-truck me-2 text-primary"></i>Editar tarifa de envío
    </h3>
</div>

<div class="card" style="max-width:600px;">
    <div class="card-body" style="padding:var(--sp-6)!important;">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Transportista" class="form-label fw-semibold"></label>
                <input asp-for="Transportista" class="form-control" />
                <span asp-validation-for="Transportista" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-3">
                <div class="col">
                    <label asp-for="ZonaDesde" class="form-label fw-semibold"></label>
                    <input asp-for="ZonaDesde" class="form-control" maxlength="8" />
                    <div class="form-text">Primeros 4 dígitos del CP de inicio</div>
                    <span asp-validation-for="ZonaDesde" class="text-danger small"></span>
                </div>
                <div class="col">
                    <label asp-for="ZonaHasta" class="form-label fw-semibold"></label>
                    <input asp-for="ZonaHasta" class="form-control" maxlength="8" />
                    <div class="form-text">Primeros 4 dígitos del CP de fin</div>
                    <span asp-validation-for="ZonaHasta" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col">
                    <label asp-for="Costo" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Costo" class="form-control" type="number" step="100" min="0" />
                    </div>
                    <span asp-validation-for="Costo" class="text-danger small"></span>
                </div>
                <div class="col">
                    <label asp-for="DiasEstimados" class="form-label fw-semibold"></label>
                    <input asp-for="DiasEstimados" class="form-control" type="number" min="1" max="30" />
                    <span asp-validation-for="DiasEstimados" class="text-danger small"></span>
                </div>
            </div>

            <div class="form-check mb-4">
                <input asp-for="Activo" class="form-check-input" type="checkbox" />
                <label asp-for="Activo" class="form-check-label">Tarifa activa</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Guardar cambios
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>
