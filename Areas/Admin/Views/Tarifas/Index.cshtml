@model List<iOStore.Models.TarifaEnvio>
@{
    ViewData["Title"] = "Tarifas de Envío";
    Layout = "/Views/Shared/_Layout.Admin.cshtml";

    // Mapa de zonas argentinas por prefijo CP (4 dígitos)
    string DescZona(string desde, string hasta)
    {
        if (desde == "0000" && hasta == "9999") return "Todo el país";
        if (desde == "1000" && hasta == "1999") return "AMBA (CABA + GBA)";
        if (desde == "2000" && hasta == "3999") return "Buenos Aires Pcia. + Litoral";
        if (desde == "4000" && hasta == "5999") return "Centro, NOA, Cuyo";
        if (desde == "6000" && hasta == "7999") return "Buenos Aires Pcia. sur + La Pampa";
        if (desde == "8000" && hasta == "9999") return "Patagonia";
        return $"{desde}–{hasta}";
    }
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold"><i class="bi bi-truck me-2 text-primary"></i>Tarifas de envío</h3>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-2"></i>Nueva tarifa
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Transportista</th>
                    <th>Zona (rango CP)</th>
                    <th class="text-end">Costo</th>
                    <th class="text-center">Días hábiles</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Actualizado</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    <tr>
                        <td style="font-weight:600;">@t.Transportista</td>
                        <td>
                            <code>@t.ZonaDesde</code> – <code>@t.ZonaHasta</code>
                            <div style="font-size:11px;color:var(--text-muted);">@DescZona(t.ZonaDesde, t.ZonaHasta)</div>
                        </td>
                        <td class="text-end">@(t.Costo == 0 ? "Gratis" : "$" + t.Costo.ToString("N0"))</td>
                        <td class="text-center">@(t.DiasEstimados == 0 ? "—" : t.DiasEstimados.ToString())</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-toggle-tarifa"
                                    data-id="@t.Id"
                                    style="border-radius:20px;font-size:11px;padding:2px 12px;
                                           background:@(t.Activo ? "#e8f5e9" : "#fce4ec");
                                           color:@(t.Activo ? "#1b5e20" : "#b71c1c");border:none;">
                                @(t.Activo ? "Activa" : "Inactiva")
                            </button>
                        </td>
                        <td class="text-center" style="font-size:12px;color:var(--text-muted);">
                            @t.FechaActualizacion.ToString("dd/MM/yyyy")
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@t.Id"
                               class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@t.Id" method="post" style="display:inline;">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"
                                        onclick="return confirm('¿Eliminar esta tarifa?');">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-4" style="color:var(--text-muted);">
                            No hay tarifas configuradas. Se usarán valores predeterminados.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="mt-3 p-3" style="background:#f0f4ff;border-radius:10px;border:1px solid #c7d4f5;font-size:13px;">
    <i class="bi bi-info-circle me-1 text-primary"></i>
    <strong>¿Cómo funcionan las zonas?</strong> Se comparan los primeros 4 dígitos del CP del cliente.
    <details class="mt-2">
        <summary style="cursor:pointer;font-weight:600;">Ver referencia de zonas argentinas</summary>
        <table class="table table-sm mt-2 mb-0" style="font-size:12px;">
            <thead><tr><th>Rango CP</th><th>Zona / Provincia</th></tr></thead>
            <tbody>
                <tr><td><code>0000–9999</code></td><td>Todo el país (Retiro en tienda)</td></tr>
                <tr><td><code>1000–1999</code></td><td>AMBA: CABA + Gran Buenos Aires</td></tr>
                <tr><td><code>2000–3999</code></td><td>Buenos Aires Pcia. interior norte, Santa Fe, Entre Ríos, Corrientes, Misiones, Chaco, Formosa</td></tr>
                <tr><td><code>4000–5999</code></td><td>Tucumán, Salta, Jujuy, Catamarca, Santiago del Estero, La Rioja, Córdoba, Mendoza, San Juan, San Luis</td></tr>
                <tr><td><code>6000–7999</code></td><td>Buenos Aires Pcia. sur, La Pampa</td></tr>
                <tr><td><code>8000–9999</code></td><td>Neuquén, Río Negro, Chubut, Santa Cruz, Tierra del Fuego</td></tr>
            </tbody>
        </table>
    </details>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.btn-toggle-tarifa').forEach(btn => {
            btn.addEventListener('click', async function () {
                const id = this.dataset.id;
                const resp = await fetch(`/Admin/Tarifas/Toggle/${id}`, { method: 'POST', headers: { 'RequestVerificationToken': document.querySelector('input[name=__RequestVerificationToken]')?.value ?? '' } });
                const data = await resp.json();
                if (data.ok) {
                    this.textContent = data.activo ? 'Activa' : 'Inactiva';
                    this.style.background = data.activo ? '#e8f5e9' : '#fce4ec';
                    this.style.color      = data.activo ? '#1b5e20' : '#b71c1c';
                }
            });
        });
    </script>
}
