@* ═══════════════════════════════════════════════════════════════ *@
@* Views/Admin/Usuarios/Crear.cshtml                              *@
@* ═══════════════════════════════════════════════════════════════ *@
@using iOStore.Areas.Admin.Controllers
@model CrearUsuarioViewModel
@{
    ViewData["Title"] = "Nuevo Usuario";
    Layout = "/Views/Shared/_Layout.Admin.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-person-plus me-2"></i>Nuevo Usuario
            </div>
            <div class="card-body" style="padding:var(--sp-6)!important;">
                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="mb-3">
                        <label asp-for="NombreCompleto" class="form-label fw-semibold"></label>
                        <input asp-for="NombreCompleto" class="form-control" autofocus />
                        <span asp-validation-for="NombreCompleto" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label fw-semibold"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Telefono" class="form-label fw-semibold"></label>
                            <input asp-for="Telefono" class="form-control" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Password" class="form-label fw-semibold"></label>
                            <input asp-for="Password" class="form-control" placeholder="Mínimo 6 caracteres" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="FechaIncorporacion" class="form-label fw-semibold"></label>
                            <input asp-for="FechaIncorporacion" class="form-control" type="date" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Rol" class="form-label fw-semibold"></label>
                        <select asp-for="Rol" asp-items="Model.RolesDisponibles" class="form-select">
                            <option value="">-- Seleccionar rol --</option>
                        </select>
                        <span asp-validation-for="Rol" class="text-danger small"></span>
                        <div class="form-text">
                            <i class="bi bi-info-circle me-1"></i>
                            <strong>Administrador:</strong> acceso total |
                            <strong>AdminEmpleado:</strong> CRUD inventario y ventas |
                            <strong>Cliente:</strong> solo comprar
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2 me-2"></i>Crear usuario
                        </button>
                        <a asp-action="Index" class="btn btn-ghost">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}