@model VerificarCodigoResetViewModel
@{
    ViewData["Title"] = "Verificar código";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — iOStore</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/flatly/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style> body { padding-top: 0 !important; } </style>
</head>
<body class="auth-page no-fixed-nav">

    <div style="width:100%;max-width:440px;">
        <!-- Marca -->
        <div class="auth-brand-mark">
            <div class="auth-brand-icon"><i class="bi bi-apple"></i></div>
            <div class="auth-brand-name">iOStore</div>
        </div>

        <!-- Card -->
        <div class="auth-card">
            <div class="text-center mb-4">
                <div style="font-size:2.8rem;color:var(--warning);margin-bottom:var(--sp-2);">
                    <i class="bi bi-key"></i>
                </div>
                <div class="auth-title">Verificá tu identidad</div>
                <div class="auth-sub">
                    Enviamos un código de recuperación a<br />
                    <strong style="color:var(--accent);">@Model.Email</strong>
                </div>
            </div>

            <form asp-action="VerificarCodigoReset" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Codigo" id="codigoHidden" autocomplete="one-time-code" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"
                     style="font-size:var(--text-xs);text-align:center;"></div>

                <p style="font-size:var(--text-xs);font-weight:var(--weight-medium);text-align:center;
                           color:var(--text-muted);margin-bottom:var(--sp-4);">
                    Código de verificación
                </p>

                <div class="otp-container mb-4">
                    <input type="text" class="otp-input form-control" maxlength="1"
                           inputmode="numeric" pattern="[0-9]" autofocus />
                    <input type="text" class="otp-input form-control" maxlength="1"
                           inputmode="numeric" pattern="[0-9]" />
                    <input type="text" class="otp-input form-control" maxlength="1"
                           inputmode="numeric" pattern="[0-9]" />
                    <input type="text" class="otp-input form-control" maxlength="1"
                           inputmode="numeric" pattern="[0-9]" />
                    <input type="text" class="otp-input form-control" maxlength="1"
                           inputmode="numeric" pattern="[0-9]" />
                    <input type="text" class="otp-input form-control" maxlength="1"
                           inputmode="numeric" pattern="[0-9]" />
                </div>
                <span asp-validation-for="Codigo" class="text-danger small d-block text-center mb-3"></span>

                <button type="submit" class="btn btn-primary w-100 btn-lg">
                    <i class="bi bi-shield-check me-2"></i>Verificar código
                </button>
            </form>

            <hr style="margin:var(--sp-6) 0;border-color:var(--border-light);" />

            <p style="font-size:var(--text-xs);text-align:center;color:var(--text-muted);margin-bottom:var(--sp-2);">
                ¿No recibiste el código?
            </p>
            <form asp-action="ReenviarCodigoReset" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" value="@Model.UserId" />
                <input type="hidden" name="email" value="@Model.Email" />
                <button type="submit" class="btn btn-secondary w-100 btn-sm">
                    <i class="bi bi-arrow-clockwise me-1"></i>Reenviar código
                </button>
            </form>

            <div style="text-align:center;margin-top:var(--sp-4);">
                <a asp-action="OlvidePassword"
                   style="font-size:var(--text-xs);color:var(--text-muted);text-decoration:none;">
                    <i class="bi bi-arrow-left me-1"></i>Usar otro email
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.21.0/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
