        font-size: var(--text-xs);
        font-weight: var(--weight-semibold);
        letter-spacing: .08em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: var(--sp-3);
    }

    /* ── Timeline ─────────────────────────────────────────────────── */
    .pedido-timeline { position: relative; padding-left: 36px; }
    .pedido-timeline::before {
        content: '';
        position: absolute;
        left: 15px;
        top: 8px;
        bottom: 8px;
        width: 2px;
        background: var(--border-light);
        border-radius: 2px;
    }
    .timeline-item {
        position: relative;
        display: flex;
        gap: 14px;
        padding-bottom: var(--sp-5);
    }
    .timeline-item:last-child { padding-bottom: 0; }
    .timeline-icon {
        position: absolute;
        left: -36px;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
        flex-shrink: 0;
        border: 2px solid #fff;
        box-shadow: 0 1px 4px rgba(0,0,0,.12);
    }
    .timeline-icon-estado  { background: var(--accent);   color: #fff; }
    .timeline-icon-contacto { background: #1a7f3c;         color: #fff; }
    .timeline-body { flex: 1; min-width: 0; }
    .timeline-desc {
        font-size: var(--text-sm);
        font-weight: var(--weight-semibold);
        color: var(--text-primary);
        margin-bottom: 4px;
    }
    .timeline-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        font-size: var(--text-xs);
        color: var(--text-muted);
        margin-bottom: 4px;
    }
    .timeline-obs {
        font-size: var(--text-xs);
        color: var(--text-muted);
        background: var(--surface, #f5f5f7);
        border-radius: 8px;
        padding: 6px 10px;
        margin-top: 4px;
    }
</style>
