@model iOStore.Models.Producto
@{
    ViewData["Title"] = "Eliminar Producto";
}

<div class="row justify-content-center" style="padding-top:var(--sp-6);">
    <div class="col-md-5">
        <div class="card" style="border-color:var(--danger);">
            <div class="card-body text-center" style="padding:var(--sp-8)!important;">
                @if (!string.IsNullOrEmpty(Model.ImagenUrl))
                {
                    <img src="@Model.ImagenUrl" alt="@Model.Modelo"
                         class="rounded mb-3"
                         style="max-height:140px;max-width:200px;object-fit:contain;" />
                }
                else
                {
                    <div style="width:80px;height:80px;border-radius:var(--radius-md);
                                background:var(--bg-subtle);display:flex;
                                align-items:center;justify-content:center;
                                margin:0 auto var(--sp-4);font-size:2rem;
                                color:var(--text-muted);">
                        <i class="bi bi-box-seam"></i>
                    </div>
                }

                <h5 style="font-weight:var(--weight-bold);font-size:var(--text-lg);margin-bottom:var(--sp-1);">@Model.Modelo</h5>
                <div style="font-size:var(--text-sm);color:var(--text-muted);margin-bottom:var(--sp-6);">
                    @Model.TipoProducto — $@Model.Precio.ToString("N0")
                </div>

                <div class="alert alert-warning" style="font-size:var(--text-xs);">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    El producto se marcará como <strong>inactivo</strong> (no se elimina definitivamente).
                </div>
            </div>

            <div class="card-body" style="padding:var(--sp-4) var(--sp-6)!important;
                                          border-top:1px solid var(--border-light);
                                          display:flex;gap:var(--sp-2);justify-content:flex-end;">
                <a asp-action="Index" class="btn btn-ghost">
                    <i class="bi bi-x me-1"></i>Cancelar
                </a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-2"></i>Sí, eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
