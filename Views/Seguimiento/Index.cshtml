@using iOStore.Helpers
@using iOStore.Models
@{
    ViewData["Title"] = "Seguimiento de pedido";
    var pedido          = ViewBag.Pedido          as Pedido;
    var timeline        = ViewBag.TimelinePublica as List<TimelineItem>;
    bool noEncontrado   = ViewBag.NoEncontrado == true;
    string? numero      = ViewBag.Numero as string;
}

<div class="row justify-content-center" style="padding-top:var(--sp-8);">
    <div class="col-lg-6">

        <!-- Título -->
        <div class="text-center mb-5">
            <div style="width:56px;height:56px;border-radius:50%;background:var(--accent);color:#fff;
                        font-size:1.6rem;display:flex;align-items:center;justify-content:center;
                        margin:0 auto var(--sp-3);">
                <i class="bi bi-box-seam"></i>
            </div>
            <h2 style="font-size:var(--text-xl);font-weight:var(--weight-bold);letter-spacing:-.02em;">
                Seguimiento de pedido
            </h2>
            <p style="color:var(--text-muted);font-size:var(--text-sm);">
                Ingresá tu número de seguimiento para ver el estado de tu compra.
            </p>
        </div>

        <!-- Buscador -->
        <form asp-controller="Seguimiento" asp-action="Buscar" method="get" class="mb-4">
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-search"></i></span>
                <input type="text" name="numero" class="form-control"
                       placeholder="ORD-2025-00047"
                       value="@numero"
                       style="font-family:monospace;letter-spacing:.04em;"
                       required />
                <button type="submit" class="btn btn-primary">Buscar</button>
            </div>
            <div style="font-size:var(--text-xs);color:var(--text-muted);margin-top:6px;">
                <i class="bi bi-info-circle me-1"></i>
                El número de seguimiento lo recibiste en el email de confirmación de tu pedido.
            </div>
        </form>

        <!-- Resultado no encontrado -->
        @if (noEncontrado)
        {
            <div class="alert alert-warning d-flex align-items-center gap-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill" style="font-size:1.4rem;"></i>
                <div>
                    <strong>Número no encontrado.</strong><br />
                    <span style="font-size:var(--text-xs);">
                        Verificá que el número «@numero» sea correcto y que no tenga espacios adicionales.
                    </span>
                </div>
            </div>
        }

        <!-- Resultado encontrado -->
        @if (pedido != null && timeline != null)
        {
            <div class="card">
                <div class="card-body p-0">

                    <!-- Header del pedido -->
                    <div style="padding:var(--sp-5) var(--sp-6);border-bottom:1px solid var(--border-light);
                                background:var(--surface,#f5f5f7);border-radius:var(--radius-lg) var(--radius-lg) 0 0;">
                        <div style="font-size:var(--text-xs);color:var(--text-muted);margin-bottom:4px;letter-spacing:.04em;">
                            NÚMERO DE SEGUIMIENTO
                        </div>
                        <div style="font-size:var(--text-lg);font-weight:var(--weight-bold);font-family:monospace;letter-spacing:.04em;">
                            @pedido.NumeroSeguimiento
                        </div>
                        <div class="mt-2">
                            <span class="badge badge-@FormatHelper.BadgeEstado(pedido.EstadoActual)"
                                  style="font-size:var(--text-xs);padding:5px 14px;border-radius:980px;">
                                @FormatHelper.DisplayEstado(pedido.EstadoActual)
                            </span>
                            <span style="font-size:var(--text-xs);color:var(--text-muted);margin-left:8px;">
                                Pedido el @pedido.FechaPedido.ToString("dd/MM/yyyy")
                            </span>
                        </div>
                    </div>

                    <!-- Timeline pública -->
                    <div style="padding:var(--sp-5) var(--sp-6);">
                        <div style="font-size:var(--text-xs);font-weight:var(--weight-semibold);
                                    letter-spacing:.08em;text-transform:uppercase;
                                    color:var(--text-muted);margin-bottom:var(--sp-4);">
                            Historial de estados
                        </div>

                        @if (!timeline.Any())
                        {
                            <p style="color:var(--text-muted);font-size:var(--text-sm);text-align:center;padding:var(--sp-4) 0;margin:0;">
                                <i class="bi bi-hourglass me-1"></i>Tu pedido está siendo procesado.
                            </p>
                        }
                        else
                        {
                            <div class="seg-timeline">
                                @foreach (var item in timeline)
                                {
                                    <div class="seg-timeline-item">
                                        <div class="seg-timeline-dot"></div>
                                        <div class="seg-timeline-body">
                                            <div style="font-size:var(--text-sm);font-weight:var(--weight-semibold);">
                                                @item.Descripcion
                                            </div>
                                            <div style="font-size:var(--text-xs);color:var(--text-muted);margin-top:2px;">
                                                <i class="bi bi-clock me-1"></i>@item.Fecha.ToString("dd/MM/yyyy HH:mm")
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                </div>
            </div>
        }

    </div>
</div>

<style>
    .seg-timeline { position: relative; padding-left: 24px; }
    .seg-timeline::before {
        content: '';
        position: absolute;
        left: 6px;
        top: 6px;
        bottom: 6px;
        width: 2px;
        background: var(--border-light);
        border-radius: 2px;
    }
    .seg-timeline-item {
        position: relative;
        padding-bottom: var(--sp-4);
        display: flex;
        gap: 12px;
    }
    .seg-timeline-item:last-child { padding-bottom: 0; }
    .seg-timeline-dot {
        position: absolute;
        left: -24px;
        top: 4px;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--accent);
        border: 2px solid #fff;
        box-shadow: 0 0 0 2px rgba(0,113,227,.25);
        flex-shrink: 0;
    }
    .seg-timeline-body { flex: 1; }
</style>
