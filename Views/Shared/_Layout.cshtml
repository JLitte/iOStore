<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — iOStore</title>

    <!-- Bootstrap base (Bootswatch Flatly) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/flatly/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- DataTables -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.bootstrap5.min.css" />
    <!-- iOStore Design System -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- Apple Theme (overrides + new components) -->
    <link rel="stylesheet" href="~/css/apple-theme.css" asp-append-version="true" />
</head>
<body>

<!-- ── Navbar Apple ──────────────────────────────────────────────────────── -->
<nav class="navbar navbar-expand-lg">
    <div class="container" style="max-width:980px;">

        <!-- Logo -->
        <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
            <i class="bi bi-apple"></i> iOStore
        </a>

        <!-- Toggler mobile -->
        <button class="navbar-toggler" type="button"
                data-bs-toggle="collapse" data-bs-target="#navbarApple"
                aria-controls="navbarApple" aria-expanded="false" aria-label="Menú">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarApple">
            <!-- Links categorías — centro -->
            <ul class="navbar-nav mx-auto align-items-center">
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Producto" asp-action="Catalogo"
                       asp-route-buscar="iPhone">iPhone</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Producto" asp-action="Catalogo"
                       asp-route-buscar="iPad">iPad</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Producto" asp-action="Catalogo"
                       asp-route-buscar="Mac">Mac</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Producto" asp-action="Catalogo"
                       asp-route-buscar="Watch">Watch</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Producto" asp-action="Catalogo"
                       asp-route-buscar="AirPods">AirPods</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Producto" asp-action="Catalogo">
                        Catálogo
                    </a>
                </li>
            </ul>

            <!-- Acciones — derecha -->
            <ul class="navbar-nav align-items-center gap-1">

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <!-- Ícono carrito -->
                    <li class="nav-item">
                        <a class="nav-link px-2 nav-cart-icon"
                           asp-area="" asp-controller="Carrito" asp-action="Index"
                           title="Mi carrito" style="color:var(--apple-text);">
                            <i class="bi bi-bag" style="font-size:17px;"></i>
                            <span id="carritoCount">0</span>
                        </a>
                    </li>

                    <!-- Menú usuario -->
                    <li class="nav-item dropdown">
                        <button class="btn d-flex align-items-center gap-1 px-1"
                                data-bs-toggle="dropdown" aria-expanded="false"
                                style="background:none;border:none;padding:0 4px;">
                            <span class="user-avatar">
                                @(User.Identity.Name?.Split('@')[0]?.Substring(0,1).ToUpper())
                            </span>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <h6 class="dropdown-header">
                                    <i class="bi bi-person-circle me-1"></i>
                                    @User.Identity.Name?.Split('@')[0]
                                </h6>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-area="" asp-controller="Account" asp-action="Perfil">
                                    <i class="bi bi-person"></i>Perfil
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item"
                                   asp-area="" asp-controller="Pedido" asp-action="Index">
                                    <i class="bi bi-bag-check"></i>Mis pedidos
                                </a>
                            </li>

                            @if (User.IsInRole("Administrador") || User.IsInRole("AdminEmpleado"))
                            {
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <h6 class="dropdown-header">
                                        <i class="bi bi-shield-check me-1"></i>Administración
                                    </h6>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                        <i class="bi bi-speedometer2"></i>Dashboard
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-area="" asp-controller="Producto" asp-action="Index">
                                        <i class="bi bi-box-seam"></i>Gestión Productos
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-area="Admin" asp-controller="Categorias" asp-action="Index">
                                        <i class="bi bi-tags"></i>Categorías
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item"
                                       asp-area="" asp-controller="Pedido" asp-action="Index">
                                        <i class="bi bi-list-check"></i>Todos los pedidos
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Administrador"))
                            {
                                <li>
                                    <a class="dropdown-item"
                                       asp-area="Admin" asp-controller="Usuarios" asp-action="Index">
                                        <i class="bi bi-people"></i>Gestión Usuarios
                                    </a>
                                </li>
                            }

                            <li><hr class="dropdown-divider" /></li>
                            <li>
                                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right"></i>Cerrar sesión
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </li>
                }
                else
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-area="" asp-controller="Account" asp-action="Login"
                           style="font-size:12px;color:var(--apple-text);">
                            Ingresar
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn-apple-primary" style="font-size:13px;padding:7px 16px;"
                           asp-area="" asp-controller="Account" asp-action="Register">
                            Crear cuenta
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

<!-- ── Alertas globales ───────────────────────────────────────────────────── -->
@if (TempData["Success"] != null || TempData["Error"] != null || TempData["Info"] != null)
{
    <div class="global-alerts">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Info"] != null)
        {
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                <i class="bi bi-info-circle me-2"></i>@TempData["Info"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>
}

<!-- ── Contenido principal ───────────────────────────────────────────────── -->
<main class="container py-4">
    @RenderBody()
</main>

<!-- ── Footer Apple ─────────────────────────────────────────────────────── -->
<footer class="footer-apple">
    <div class="footer-top">
        <a class="footer-brand-row" asp-area="" asp-controller="Home" asp-action="Index">
            <i class="bi bi-apple"></i> iOStore
        </a>

        <div class="footer-cols">
            <div>
                <div class="footer-col-title">Tienda</div>
                <ul class="footer-col-links">
                    <li><a asp-area="" asp-controller="Producto" asp-action="Catalogo">Catálogo completo</a></li>
                    <li><a asp-area="" asp-controller="Producto" asp-action="Catalogo" asp-route-buscar="iPhone">iPhone</a></li>
                    <li><a asp-area="" asp-controller="Producto" asp-action="Catalogo" asp-route-buscar="iPad">iPad</a></li>
                    <li><a asp-area="" asp-controller="Producto" asp-action="Catalogo" asp-route-buscar="Mac">Mac</a></li>
                </ul>
            </div>
            <div>
                <div class="footer-col-title">Productos</div>
                <ul class="footer-col-links">
                    <li><a asp-area="" asp-controller="Producto" asp-action="Catalogo" asp-route-buscar="Watch">Apple Watch</a></li>
                    <li><a asp-area="" asp-controller="Producto" asp-action="Catalogo" asp-route-buscar="AirPods">AirPods</a></li>
                    <li><a asp-area="" asp-controller="Producto" asp-action="Catalogo" asp-route-buscar="Accesorios">Accesorios</a></li>
                </ul>
            </div>
            <div>
                <div class="footer-col-title">Cuenta</div>
                <ul class="footer-col-links">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li><a asp-area="" asp-controller="Account" asp-action="Perfil">Mi perfil</a></li>
                        <li><a asp-area="" asp-controller="Pedido" asp-action="Index">Mis pedidos</a></li>
                        <li><a asp-area="" asp-controller="Carrito" asp-action="Index">Mi carrito</a></li>
                    }
                    else
                    {
                        <li><a asp-area="" asp-controller="Account" asp-action="Login">Iniciar sesión</a></li>
                        <li><a asp-area="" asp-controller="Account" asp-action="Register">Crear cuenta</a></li>
                    }
                </ul>
            </div>
            <div>
                <div class="footer-col-title">Soporte</div>
                <ul class="footer-col-links">
                    <li><a asp-area="" asp-controller="Home" asp-action="Privacy">Privacidad</a></li>
                    <li><a href="#">Términos y condiciones</a></li>
                    <li><a href="#">Centro de ayuda</a></li>
                    <li><a href="#">Garantía oficial</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="footer-bottom">
        <p class="footer-legal">
            Copyright &copy; @DateTime.Now.Year iOStore. Todos los derechos reservados.
            <span class="sep">|</span>
            <a href="#">Privacidad</a>
            <span class="sep">·</span>
            <a href="#">Términos</a>
            <span class="sep">·</span>
            <span>AR</span>
        </p>
    </div>
</footer>

<!-- ── Toast container ──────────────────────────────────────────────────── -->
<div id="toastContainer"></div>

<!-- ── Scripts ──────────────────────────────────────────────────────────── -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script src="~/js/apple-animations.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)

<!-- Contador carrito -->
@if (User.Identity?.IsAuthenticated == true)
{
    <script>
        (function actualizarContadorCarrito() {
            fetch('/Carrito/ContadorCarrito')
                .then(r => r.json())
                .then(d => {
                    const badge = document.getElementById('carritoCount');
                    if (badge) {
                        const total = d.totalItems || 0;
                        badge.textContent = total;
                        badge.style.display = total > 0 ? 'inline-flex' : 'none';
                    }
                })
                .catch(() => {});
        })();
    </script>
}

<!-- Búsqueda navbar suggestions -->
<div id="navSearchSuggestions"
     style="display:none;position:fixed;z-index:10000;background:#fff;
            border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,0.12);
            overflow:hidden;max-height:360px;overflow-y:auto;">
</div>

</body>
</html>
