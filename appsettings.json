{
  "ConnectionStrings": {
    "DefaultConnection": "#{DB_CONNECTION}#"
  },

  "EmailSettings": {
    "Host": "#{SMTP_HOST}#",
    "Port": "#{SMTP_PORT}#",
    "Usuario": "#{SMTP_USER}#",
    "Password": "#{SMTP_PASSWORD}#",
    "Remitente": "iOStore"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/iostore-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",

  "CotizacionFallback": {
    "DolarBlue": 1200.00,
    "DolarTarjeta": 1500.00
  },

  "Envio": {
    "CodigoPostalOrigen": "6300",
    "EnvioGratisDesde": 150000.00,
    "EnvioGratisDesdeUSD": 2000,
    "EnvioGratisDesdeARS": 3000000,
    "TarifaDefectoARS": 8000,
    "TimeoutApiSegundos": 3,
    "DatosBancarios": {
      "CBU": "0000003100012345678900",
      "Alias": "iostore.pagos",
      "Titular": "iOStore SRL",
      "Banco": "Banco Galicia"
    }
  }
}
